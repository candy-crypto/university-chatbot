# If you use Weaviate Cloud, the docs say you need the REST endpoint URL 
# and admin API key, and the client can configure gRPC automatically 
# from the REST endpoint
# Documentation: 
# https://docs.weaviate.io/weaviate/quickstart

OPENAI_API_KEY=

OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
TOP_K=5

DATABASE_URL=postgresql://user:pass@host:5432/univeristy_chatbot

# Weaviate connection mode: local or cloud
WEAVIATE_MODE=local

# Local Weaviate
WEAVIATE_HTTP_HOST=localhost
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_HOST=localhost
WEAVIATE_GRPC_PORT=50051

# Weaviate Cloud
#WEAVIATE_URL=https://your-cluster.weaviate.network
#WEAVIATE_API_KEY=your_weaviate_api_key

# Collection name
WEAVIATE_COLLECTION=DepartmentChunk